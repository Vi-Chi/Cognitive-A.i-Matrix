# Cognitive Matrix — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# AnythingLLM / Omni API key (if using external orchestration)
OMNI_API_KEY=your_key_here

# Anthropic Claude API key (optional — only needed for ClaudeAgent connector)
ANTHROPIC_API_KEY=

# OpenAI API key (optional — only needed for OpenAIAgent connector)
OPENAI_API_KEY=

# Groq API key (optional — only needed for GroqAgent connector)
GROQ_API_KEY=

# Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE=http://localhost:11434
