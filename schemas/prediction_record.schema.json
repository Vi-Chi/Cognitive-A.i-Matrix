{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vi-Chi/MEBUS/schemas/prediction_record.schema.json",
  "title": "PredictionRecord",
  "description": "The cognition synapse. Emitted by Orbi/Urbi agents in WAKE, consumed by the Urbi Dream Layer (ΦΔ). Carried on MΣBUS as the π of an m.prediction_record message.",
  "type": "object",
  "required": ["record_id", "belief_state", "predicted_outcome", "domain", "mu_at_time"],
  "additionalProperties": false,
  "properties": {
    "record_id":       { "type": "string" },
    "belief_state":    { "type": "object", "description": "GSS region ref (centroid + radius)" },
    "predicted_outcome": { "type": "object", "description": "expected state" },
    "actual_outcome":  { "type": ["object", "null"], "description": "observed state, filled later" },
    "prediction_error": { "type": ["number", "null"], "description": "KL divergence predicted vs actual" },
    "confidence":      { "type": "number", "minimum": 0, "maximum": 1 },
    "domain":          { "type": "string", "description": "DomainTag, e.g. maritime.nav" },
    "causal_parents":  { "type": "array", "items": { "type": "string" }, "description": "CGM node refs (genealogy)" },
    "mu_at_time":      { "type": "string", "enum": ["WAKE", "LIMINAL", "DREAM"] }
  }
}
