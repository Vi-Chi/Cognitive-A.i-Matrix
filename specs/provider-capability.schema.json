{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vi-Chi/project-autopoiesis/specs/provider-capability.schema.json",
  "title": "ProviderCapability",
  "type": "object",
  "required": ["provider_id", "name", "compute_tiers", "privacy_class", "trust_score", "status"],
  "additionalProperties": false,
  "properties": {
    "provider_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "network": {
      "type": "string",
      "enum": ["local", "icp", "akash", "golem", "bittensor", "commercial_api", "other"]
    },
    "compute_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["local_cpu", "local_accelerator", "local_gpu", "decentralized_compute", "commercial_api", "canister", "offline"]
      }
    },
    "supported_runtimes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "price_model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "currency": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "estimated_unit_cost": {
          "type": "number",
          "minimum": 0
        },
        "simulation_only": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "privacy_class": {
      "type": "string",
      "enum": ["local_private", "sanitized_only", "public_only", "unknown"]
    },
    "trust_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "benchmark_history": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "failure_history": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "approved_for_simulation", "approved_for_public_data", "blocked", "retired"]
    },
    "notes": {
      "type": "string"
    }
  }
}
